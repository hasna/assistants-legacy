{
  "name": "@hasna/assistants-sdk",
  "version": "0.1.4",
  "description": "Zero-dependency TypeScript SDK for @hasna/assistants — connect to a local assistant API",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target browser --format esm && bun tsc --emitDeclarationOnly --declaration --outDir dist",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/bun": "^1.3.8",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hasna/assistants.git",
    "directory": "packages/sdk"
  },
  "keywords": [
    "ai",
    "assistant",
    "sdk",
    "hasna",
    "claude"
  ],
  "engines": {
    "node": ">=18"
  }
}
