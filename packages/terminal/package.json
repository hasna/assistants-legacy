{
  "name": "@hasna/assistants",
  "version": "0.1.0",
  "description": "AI assistant that runs in your terminal",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "import": "./dist/lib.js"
    }
  },
  "main": "./dist/lib.js",
  "types": "./dist/lib.d.ts",
  "bin": {
    "assistants": "./dist/cli.js",
    "ast": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/hasna/assistants.git",
    "directory": "packages/terminal"
  },
  "homepage": "https://github.com/hasna/assistants#readme",
  "bugs": {
    "url": "https://github.com/hasna/assistants/issues"
  },
  "keywords": [
    "ai",
    "assistant",
    "terminal",
    "cli",
    "ai-sdk",
    "chatbot",
    "opentui",
    "bun"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun run src/index.tsx",
    "build": "bun run scripts/build.ts",
    "build:types": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run clean && pnpm run build"
  },
  "dependencies": {
    "@opentui/core": "0.1.90",
    "@opentui/react": "0.1.90",
    "chalk": "4.1.2",
    "cli-boxes": "3.0.0",
    "indent-string": "5.0.0",
    "marked": "^17.0.1",
    "marked-terminal": "^7.3.0",
    "react": "^19.2.4",
    "slice-ansi": "8.0.0",
    "yoga-layout": "3.2.1"
  },
  "devDependencies": {
    "@hasna/assistants-core": "workspace:*",
    "@hasna/assistants-shared": "workspace:*",
    "@hasna/runtime-bun": "workspace:*",
    "@types/bun": "^1.3.8",
    "@types/react": "^19.2.13",
    "bun-types": "^1.3.9",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18",
    "bun": ">=1.2"
  }
}
