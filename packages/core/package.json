    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18",
    "bun": ">=1.0"
  },
  "peerDependencies": {
    "@hasna/runtime-bun": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@hasna/runtime-bun": {
      "optional": true
    }
  }
}
