{
  "name": "@hasna/assistants-core",
  "version": "0.1.0",
  "private": true,
  "description": "Core runtime library for building AI assistants with the AI SDK",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./runtime": {
      "types": "./src/runtime/index.ts",
      "import": "./src/runtime/index.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "import": "./src/*.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/hasna/assistants.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/hasna/assistants/tree/main/packages/core#readme",
  "bugs": {
    "url": "https://github.com/hasna/assistants/issues"
  },
  "keywords": [
    "ai",
    "assistant",
    "claude",
    "anthropic",
    "assistant",
    "tools",
    "llm"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test --timeout 60000",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.79",
    "@ai-sdk/google": "^3.0.79",
    "@ai-sdk/mistral": "^3.0.37",
