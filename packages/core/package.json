    "@aws-sdk/credential-providers": "^3.985.0",
    "@hasna/assistants-shared": "workspace:*",
    "@hasna/attachments": "^1.0.19",
    "@hasna/configs": "^0.2.25",
    "@hasna/connectors": "^0.2.7",
    "@hasna/contacts": "^0.4.2",
    "@hasna/conversations": "^0.1.18",
    "@hasna/crawl": "^0.4.0",
    "@hasna/deployment": "^0.0.2",
    "@hasna/economy": "^0.2.6",
    "@hasna/emails": "^0.4.29",
    "@hasna/hooks": "^0.2.8",
    "@hasna/implementations": "^0.1.0",
    "@hasna/logs": "^0.3.12",
    "@hasna/mcps": "^0.0.6",
    "@hasna/mementos": "^0.3.9",
    "@hasna/microservices": "^0.0.10",
    "@hasna/prompts": "^0.3.5",
    "@hasna/recordings": "^0.1.4",
    "@hasna/sandboxes": "^0.1.14",
    "@hasna/secrets": "^0.1.0",
    "@hasna/sessions": "^0.11.6",
    "@hasna/skills": "^0.1.8",
    "@hasna/todos": "^0.9.23",
    "ai": "^6.0.191",
    "ajv": "^8.17.1",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "mailparser": "^3.9.3",
    "mdast-util-heading-range": "^4.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.0",
    "remark-parse": "^11.0.0",
